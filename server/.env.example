# ─────────────────────────────────────────────────────────────
# CivicConnect MongoDB API — Environment Variables
# Copy this file to ".env" and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=ADMIN"

# Database name inside the cluster
DB_NAME="civicconnect"

# Secret used to sign JWT access tokens (use a long random string)
JWT_SECRET="change-me-to-a-long-random-string"

# How long access tokens stay valid
JWT_EXPIRES_IN="7d"

# Port the API listens on
PORT="4000"

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN="http://localhost:8080,http://localhost:5173"

# Secret admin access code used by the /api/auth/admin-login endpoint
ADMIN_ACCESS_CODE="CIVIC-ADMIN-2024"
