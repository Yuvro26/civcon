# ─────────────────────────────────────────────────────────────
# CivicConnect — Environment Variables
# Copy this file to ".env" and fill in values as needed:
#   cp .env.example .env
#
# The app runs fully on demo/dummy data WITHOUT any of these.
# Only set them when you connect a real backend.
# ─────────────────────────────────────────────────────────────

# Public app config (exposed to the browser — must start with VITE_)
VITE_APP_NAME="CivicConnect"
VITE_APP_URL="http://localhost:8080"

# Base URL of your backend API (when you add one)
VITE_API_BASE_URL=""

# ── Backend / server-only secrets (NEVER prefix with VITE_) ──
# These are only read on the server and never shipped to the browser.

# Database connection string (e.g. PostgreSQL / MongoDB)
DATABASE_URL=""

# AWS integration (optional)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
